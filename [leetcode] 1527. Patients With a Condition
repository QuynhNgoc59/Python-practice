import pandas as pd

def find_patients(patients: pd.DataFrame) -> pd.DataFrame:
    # Find patients diagnosed with Type I Diabetes
    return (
        patients[
            (patients['conditions'].str.contains(' DIAB1')) |
            (patients['conditions'].str.startswith('DIAB1'))
            ]
    )
