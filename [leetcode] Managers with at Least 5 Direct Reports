import pandas as pd

def find_managers(employee: pd.DataFrame) -> pd.DataFrame:
    # Find managers with at least 5 direct reporters
    return (
        employee
        .groupby(['managerId'])['id']
        .nunique()
        .reset_index(name='reporter_count')
        .query('reporter_count >= 5')
        .drop(columns=['reporter_count'])
        .merge(employee, left_on='managerId', right_on='id', how='inner')[['name']]
    )
