import pandas as pd

def analyze_dna_patterns(samples: pd.DataFrame) -> pd.DataFrame:
    # Identify if each sample_id belongs to specific patterns
    patterns_recognition = (
        samples
        .assign(
            has_start = lambda df: df['dna_sequence'].str.startswith('ATG').astype(int),
            has_stop=lambda df: df['dna_sequence'].str.endswith(('TAA', 'TAG', 'TGA')).astype(int),
            has_atat=lambda df: df['dna_sequence'].str.contains('ATAT').astype(int),
            has_ggg=lambda df: df['dna_sequence'].str.contains('GGG').astype(int)
        )
        .sort_values(by='sample_id')
    )

    return patterns_recognition
