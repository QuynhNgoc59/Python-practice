import pandas as pd

def most_friends(request_accepted: pd.DataFrame) -> pd.DataFrame:
    # Find the person having the highest number of friend requests + accepted requests
    highest_friends = (
       pd
       .concat([request_accepted.requester_id, request_accepted.accepter_id])
       .to_frame(name='id')
       .value_counts()
       .reset_index(name='num')
       .sort_values(by='num', ascending=False)
       .head(1)
    )

    return highest_friends
