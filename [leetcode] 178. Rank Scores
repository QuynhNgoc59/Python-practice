import pandas as pd

def order_scores(scores: pd.DataFrame) -> pd.DataFrame:
    # Identify rankings over all game IDs
    return (
        scores
        .assign(
            rank = lambda df: df['score'].rank(method='dense', ascending=False)
        )
        .sort_values(by='rank')[['score', 'rank']]
    )
