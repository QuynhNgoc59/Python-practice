import pandas as pd

def analyze_subscription_conversion(user_activity: pd.DataFrame) -> pd.DataFrame:
    # Calculate avg duration per trial & paid subscription per user
    avg_duration = (
        user_activity
        .assign (
            trial_duration = lambda df: df['activity_duration'].where(df['activity_type'] == 'free_trial'),
            paid_duration = lambda df: df['activity_duration'].where(df['activity_type'] == 'paid')
        )
        .groupby('user_id')
        .agg(
            trial_avg_duration = ('trial_duration', 'mean'),
            paid_avg_duration = ('paid_duration', 'mean')
        )
        .add(1e-10)
        .round(2)
        .reset_index()
        .query('paid_avg_duration > 0')
        .sort_values(by='user_id', ascending=True)
    )

    return avg_duration
